# ─────────────────────────────────────────────────────────────────────────────
# NEXOVITA HEALTH — Environment Configuration
# Copy this file to .env.local and fill in your values.
# Production (Cloud Run + Cloudflare): see deploy/README.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Local PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexovita"

# Cloud SQL via Unix socket (Cloud Run, africa-south1 / Johannesburg):
# DATABASE_URL="postgresql://nexovita:PASSWORD@/nexovita?host=/cloudsql/PROJECT:africa-south1:INSTANCE"

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-secret-key-at-least-32-chars-long"

# Session cookie name (optional, defaults to nexovita_session)
SESSION_COOKIE_NAME="nexovita_session"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Cron (Cloud Scheduler → POST /api/cron/*) ────────────────────────────────
# Generate with: openssl rand -base64 32
# CRON_SECRET=""

# ── Email — Resend (invitations, password reset, alerts) ──────────────────
# Get your API key from https://resend.com/api-keys
# EMAIL_FROM must use an address on a domain you verified in Resend
RESEND_API_KEY="re_xxxx"
EMAIL_FROM="Nexovita Health <no-reply@nexovita.health>"

# ── File Storage ─────────────────────────────────────────────────────────────
# local — dev only (do not use on Cloud Run)
# s3    — AWS S3, Cloudflare R2, or GCS via S3-compatible API
# gcs   — alias for s3 with GCS endpoint (see below)
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage/uploads"

# Object storage (STORAGE_PROVIDER=s3 or gcs)
# AWS_REGION="auto"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET="nexovita-uploads"

# Custom endpoint (required for R2 and GCS; omit for AWS S3)
# Cloudflare R2:
# S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# Google Cloud Storage (S3 interop):
# S3_ENDPOINT="https://storage.googleapis.com"
# S3_FORCE_PATH_STYLE="true"

# ── Optional: Observability ──────────────────────────────────────────────────
# SENTRY_DSN=""
# LOG_LEVEL="info"

  patient        Patient        @relation(fields: [patientId], references: [id])
  visitLog       VisitLog?      @relation(fields: [visitLogId], references: [id])
  reportedBy     User           @relation("IncidentsReported", fields: [reportedById], references: [id])
  assignedTo     User?          @relation("IncidentsAssigned", fields: [assignedToId], references: [id])
  escalations    Escalation[]

  @@index([orgId])
  @@index([patientId])
  @@index([visitLogId])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([status, severity])
  @@index([deletedAt])
  @@map("incidents")
}

model FamilyCaregiverAccount {

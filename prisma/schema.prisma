  patient        Patient              @relation(fields: [patientId], references: [id])
  createdBy      User                 @relation("EscalationsCreated", fields: [createdById], references: [id])
  assignedTo     User?                @relation("EscalationsAssigned", fields: [assignedToId], references: [id])

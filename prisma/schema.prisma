  revokedAt                DateTime?           @map("revoked_at")
  createdById              String?             @map("created_by_id")
  createdAt                DateTime            @default(now()) @map("created_at")

  org                      Organization        @relation(fields: [orgId], references: [id])
  patient                  Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  familyCaregiverAccount   FamilyCaregiverAccount? @relation(fields: [familyCaregiverAccountId], references: [id], onDelete: Cascade)
  createdBy                User?               @relation("PortalTokenCreatedBy", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([patientId])
  @@index([familyCaregiverAccountId])
  @@index([expiresAt])
  @@map("portal_access_tokens")
}

model PayerAuthorisation {
  id                  String                   @id @default(uuid())
  orgId               String                   @map("org_id")
  patientId           String                   @map("patient_id")

  payerName           String                   @map("payer_name")
  payerType           String?                  @map("payer_type")
  authorisationNumber String                   @map("authorisation_number")
  serviceCode         String?                  @map("service_code")
  status              PayerAuthorisationStatus @default(pending)
  startDate           DateTime                 @map("start_date")
  endDate             DateTime                 @map("end_date")
  unitsAuthorised     Int                      @map("units_authorised")
  unitsUsed           Int                      @default(0) @map("units_used")
  unitType            String                   @default("visit") @map("unit_type")
  notes               String?

  deletedAt           DateTime?                @map("deleted_at")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  org                 Organization             @relation(fields: [orgId], references: [id])
  patient             Patient                  @relation(fields: [patientId], references: [id])
  claims              Claim[]

  @@unique([orgId, authorisationNumber])
  @@index([orgId])
  @@index([patientId])
  @@index([status])
  @@index([endDate])
  @@index([deletedAt])
  @@map("payer_authorisations")
}

model Claim {
  id                  String              @id @default(uuid())
  orgId               String              @map("org_id")
  patientId           String              @map("patient_id")
  visitLogId          String              @unique @map("visit_log_id")
  authorisationId     String?             @map("authorisation_id")
  createdById         String              @map("created_by_id")

  claimNumber         String?             @map("claim_number")
  status              ClaimStatus         @default(draft)
  payerName           String              @map("payer_name")
  serviceCode         String              @map("service_code")
  serviceDate         DateTime            @map("service_date")
  units               Int                 @default(1)
  unitType            String              @default("visit") @map("unit_type")
  totalAmount         Decimal             @default(0) @map("total_amount") @db.Decimal(10, 2)
  diagnosisCodes      Json                @default("[]") @map("diagnosis_codes")
  procedureCodes      Json                @default("[]") @map("procedure_codes")
  denialReason        String?             @map("denial_reason")
  metadata            Json                @default("{}")

  submissionBatchId   String?             @map("submission_batch_id")
  queuedAt            DateTime?           @map("queued_at")
  submittedAt         DateTime?           @map("submitted_at")
  paidAt              DateTime?           @map("paid_at")
  deniedAt            DateTime?           @map("denied_at")
  voidedAt            DateTime?           @map("voided_at")
  deletedAt           DateTime?           @map("deleted_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  org                 Organization        @relation(fields: [orgId], references: [id])
  patient             Patient             @relation(fields: [patientId], references: [id])
  visitLog            VisitLog            @relation(fields: [visitLogId], references: [id])
  authorisation       PayerAuthorisation? @relation(fields: [authorisationId], references: [id])
  createdBy           User                @relation("ClaimsCreatedBy", fields: [createdById], references: [id])
  submissionBatch     ClaimSubmissionBatch? @relation(fields: [submissionBatchId], references: [id])

  @@unique([orgId, claimNumber])
  @@index([orgId])
  @@index([patientId])
  @@index([authorisationId])
  @@index([createdById])
  @@index([submissionBatchId])
  @@index([status])
  @@index([serviceDate])
  @@index([deletedAt])
  @@map("claims")
}

model ClaimSubmissionBatch {
  id                String           @id @default(uuid())
  orgId             String           @map("org_id")
  batchNumber       String           @map("batch_number")
  status            ClaimBatchStatus @default(submitted)
  claimCount        Int              @map("claim_count")
  totalAmount       Decimal          @map("total_amount") @db.Decimal(12, 2)
  payerName         String?          @map("payer_name")
  clearinghouseRef  String?                    @map("clearinghouse_ref")
  transportMode     String?                    @map("transport_mode")
  transportStatus   ClaimBatchTransportStatus? @default(file_only) @map("transport_status")
  transportMessage  String?                    @map("transport_message")
  transmittedAt     DateTime?                  @map("transmitted_at")
  submittedById     String                     @map("submitted_by_id")
  submittedAt       DateTime                   @default(now()) @map("submitted_at")
  createdAt         DateTime                   @default(now()) @map("created_at")

  org               Organization     @relation(fields: [orgId], references: [id])
  submittedBy       User             @relation("ClaimBatchesSubmittedBy", fields: [submittedById], references: [id])
  claims            Claim[]

  @@unique([orgId, batchNumber])
  @@index([orgId])
  @@index([status])
  @@index([submittedAt])
  @@map("claim_submission_batches")
}

model EmailDeliveryLog {
  id                String               @id @default(uuid())
  orgId             String?              @map("org_id")
  to                String
  subject           String
  template          String

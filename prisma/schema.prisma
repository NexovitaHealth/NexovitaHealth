  providerMessageId String?              @map("provider_message_id")
  metadata          Json                 @default("{}")
  sentAt            DateTime?            @map("sent_at")
  bouncedAt         DateTime?            @map("bounced_at")
  nextRetryAt       DateTime?            @map("next_retry_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  org               Organization?        @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([template])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("email_delivery_logs")
}

// DOCUMENTS & FILE ATTACHMENTS

model FileAttachment {
  id           String  @id @default(uuid())
  orgId        String  @map("org_id")
  uploadedById String  @map("uploaded_by_id")
  
  // Polymorphic: attach to patient, task, or org
  patientId    String? @map("patient_id")
  taskId       String? @map("task_id")
  
  filename     String
  originalName String  @map("original_name")
  mimeType     String  @map("mime_type")
  sizeBytes    Int     @map("size_bytes")
  storageKey   String  @map("storage_key") // path in local/S3
  url          String? // presigned or served URL
  
  documentType String? @map("document_type") // "clinical_note", "lab_result", etc.
  description  String?
  
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  patient      Patient?     @relation(fields: [patientId], references: [id])
  task         Task?        @relation(fields: [taskId], references: [id])

  @@index([orgId])
  @@index([patientId])
  @@index([taskId])
  @@map("file_attachments")
}

model PatientDocument {
  id           String   @id @default(uuid())
  patientId    String   @map("patient_id")
  uploadedById String   @map("uploaded_by_id")
  title        String
  documentType String   @map("document_type")
  fileUrl      String   @map("file_url")
  fileKey      String   @map("file_key")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  isVerified   Boolean  @default(false) @map("is_verified")
  verifiedBy   String?  @map("verified_by")
  verifiedAt   DateTime? @map("verified_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")

  patient      Patient  @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_documents")
}

// AUDIT TRAIL

model AuditLog {
  id           String      @id @default(uuid())
  orgId        String?     @map("org_id")
  actorId      String      @map("actor_id")
  action       AuditAction
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  patientId    String?     @map("patient_id")
  taskId       String?     @map("task_id")
  metadata     Json        @default("{}")

// MESSAGING & NOTIFICATIONS

model MessageThread {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  patientId  String?  @map("patient_id")
  subject    String?
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org          Organization @relation(fields: [orgId], references: [id])
  patient      Patient?     @relation(fields: [patientId], references: [id])
  messages     Message[]
  participants MessageThreadParticipant[]

  @@index([orgId])
  @@index([patientId])
  @@index([deletedAt])
  @@map("message_threads")
}

model MessageThreadParticipant {
  id         String   @id @default(uuid())
  threadId   String   @map("thread_id")
  userId     String   @map("user_id")
  lastReadAt DateTime? @map("last_read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
  @@map("message_thread_participants")
}

model Message {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  threadId   String?  @map("thread_id")
  senderId   String   @map("sender_id")
  channel    String   @default("internal") // internal | whatsapp | sms
  subject    String?
  body       String
  recipients Json     @default("[]") // array of user IDs
  isRead     Boolean  @default(false) @map("is_read")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime @default(now()) @map("created_at")

  org        Organization @relation(fields: [orgId], references: [id])
  thread     MessageThread? @relation(fields: [threadId], references: [id])
  sender     User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([orgId])
  @@index([threadId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   // "alert", "task_assigned", "invite", etc.
  title      String
  body       String
  actionUrl  String?  @map("action_url")
  isRead     Boolean  @default(false) @map("is_read")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Announcement {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  authorId  String   @map("author_id")
  title     String
  body      String
  priority  String   @default("normal") // normal | urgent
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("announcements")
}

// CLINICAL ALERTS

model ClinicalAlert {
  id           String        @id @default(uuid())
  patientId    String        @map("patient_id")
  orgId        String        @map("org_id")
  vitalId      String?       @map("vital_id")
